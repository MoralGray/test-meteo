{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "name": "mg-api-axios-1",
    "project": {
        "type": "library"
    },
    "sourceRoot": "packages/mg-api-axios-1/src",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run build",
                "cwd": "packages/mg-api-axios-1"
            }
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run lint",
                "cwd": "packages/mg-api-axios-1"
            }
        },
        "typecheck": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm run typecheck",
                "cwd": "packages/mg-api-axios-1"
            }
        }
    }
}
