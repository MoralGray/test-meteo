{
    "name": "mg-weather",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite --port $MG_WEATHER_PORT",
        "build": "tsc -b && vite build",
        "typecheck": "tsc -b",
        "format": "npx biome format --write .",
        "lint": "npx biome lint --write .",
        "check": "npx biome check --write . && npm run typecheck",
        "preview": "vite preview"
    },
    "dependencies": {
        "@mg-nx-forge/mg-api-axios-1": "^0.0.1",
        "@mg-nx-forge/mg-ui-shadcn-4": "^0.0.1",
        "@tailwindcss/vite": "4.2.4",
        "clsx": "2.1.1",
        "lucide-react": "0.562.0",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-router-dom": "^7.15.0",
        "sonner": "2.0.7",
        "tailwindcss": "4.1.17",
        "tw-animate-css": "1.4.0",
        "zustand": "^5.0.0",
        "zod": "3.25.76"
    },
    "devDependencies": {
        "@types/node": "24.10.1",
        "@types/react": "19.2.5",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "5.2.0",
        "typescript": "5.9.3",
        "vite": "8.0.10"
    }
}
